generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  STAFF
}

enum UserPermissionEffect {
  ALLOW
  DENY
}

enum MovementType {
  IN
  OUT
}

enum MovementReason {
  PURCHASE
  PROJECT
  DAMAGED
  EXPIRED
  NATURAL_LOSS
  STOCKTAKE_ADJUST
  TRANSFER_OUT
  TRANSFER_IN
  VOID
}

enum StocktakeStatus {
  DRAFT
  APPROVED
  VOIDED
}

enum InventoryDocumentKind {
  IMPORT
  EXPORT
  TRANSFER
  OPENING
  ADJUSTMENT
}

enum InventoryDocumentStatus {
  DRAFT
  POSTED
  VOIDED
}

enum FundDocumentKind {
  RECEIPT
  PAYMENT
}

enum FundDocumentStatus {
  DRAFT
  POSTED
  VOIDED
}

enum PeriodLockScope {
  INVENTORY
  FUND
  ALL
}

enum DocumentAuditAction {
  CREATE
  POST
  EDIT_DRAFT
  EDIT_POSTED
  VOID
  DELETE_DRAFT
}

enum ProjectStatus {
  ACTIVE
  CLOSED
}

enum MaterialKind {
  MATERIAL
  VEHICLE
  MACHINE
}

enum TrackingMode {
  QUANTITY
  HOURS
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  passwordHash      String
  name              String
  role              Role                @default(STAFF)
  createdAt         DateTime            @default(now())
  movements         StockMovement[]
  stocktakesCreated Stocktake[]         @relation("created")
  stocktakesApproved Stocktake[]        @relation("approved")
  documentsCreated  InventoryDocument[] @relation("DocumentCreatedBy")
  documentsUpdated  InventoryDocument[] @relation("DocumentUpdatedBy")
  documentsPosted   InventoryDocument[] @relation("DocumentPostedBy")
  documentsVoided   InventoryDocument[] @relation("DocumentVoidedBy")
  documentAuditLogs DocumentAuditLog[]
  materialNormsCreated MaterialNorm[]    @relation("MaterialNormCreatedBy")
  materialNormsUpdated MaterialNorm[]    @relation("MaterialNormUpdatedBy")
  fundDocumentsCreated FundDocument[]     @relation("FundDocumentCreatedBy")
  fundDocumentsPosted  FundDocument[]     @relation("FundDocumentPostedBy")
  fundDocumentsVoided  FundDocument[]     @relation("FundDocumentVoidedBy")
  fundDocumentAuditLogs FundDocumentAuditLog[]
  periodLocksCreated AccountingPeriodLock[] @relation("PeriodLockCreatedBy")
  positionAssignments UserPositionAssignment[]
  permissionOverrides UserPermissionOverride[]
}

model Permission {
  id            String                   @id @default(cuid())
  code          String                   @unique
  name          String
  category      String
  description   String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  positions     PositionPermission[]
  userOverrides UserPermissionOverride[]
}

model UserPosition {
  id          String                   @id @default(cuid())
  code        String                   @unique
  name        String
  description String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  permissions PositionPermission[]
  users       UserPositionAssignment[]
}

model PositionPermission {
  id           String       @id @default(cuid())
  positionId   String
  position     UserPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([positionId, permissionId])
  @@index([permissionId])
}

model UserPositionAssignment {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionId String
  position   UserPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([userId, positionId])
  @@index([positionId])
}

model UserPermissionOverride {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission           @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  effect       UserPermissionEffect
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([userId, permissionId])
  @@index([permissionId])
  @@index([effect])
}

model Unit {
  id        String     @id @default(cuid())
  name      String     @unique
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  materials Material[]
}

model Supplier {
  id        String              @id @default(cuid())
  code      String              @unique
  taxCode   String?
  name      String
  address   String?
  note      String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  documents InventoryDocument[]
}

model Material {
  id             String                  @id @default(cuid())
  name           String
  code           String                  @unique
  unit           String
  unitId         String?
  unitRef        Unit?                   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  kind           MaterialKind            @default(MATERIAL)
  trackingMode   TrackingMode            @default(QUANTITY)
  minStock       Float                   @default(0)
  createdAt      DateTime                @default(now())
  movements      StockMovement[]
  stocktakeItems StocktakeItem[]
  documentLines  InventoryDocumentLine[]
  materialNorms  MaterialNorm[]

  @@index([unitId])
  @@index([kind])
  @@index([trackingMode])
}

model Warehouse {
  id                    String              @id @default(cuid())
  name                  String
  code                  String              @unique
  isDefault             Boolean             @default(false)
  createdAt             DateTime            @default(now())
  movements             StockMovement[]
  stocktakes            Stocktake[]
  inventoryDocuments    InventoryDocument[] @relation("DocumentWarehouse")
  fromTransferDocuments InventoryDocument[] @relation("DocumentFromWarehouse")
  toTransferDocuments   InventoryDocument[] @relation("DocumentToWarehouse")
  projects              Project[]
}

model StockMovement {
  id                    String                 @id @default(cuid())
  materialId            String
  material              Material               @relation(fields: [materialId], references: [id])
  warehouseId           String
  warehouse             Warehouse              @relation(fields: [warehouseId], references: [id])
  type                  MovementType
  quantity              Float
  reason                MovementReason
  note                  String?
  transferId            String?
  stocktakeId           String?
  stocktake             Stocktake?             @relation("stocktakeAdjustments", fields: [stocktakeId], references: [id])
  documentId            String?
  document              InventoryDocument?     @relation(fields: [documentId], references: [id])
  documentLineId        String?
  documentLine          InventoryDocumentLine? @relation(fields: [documentLineId], references: [id])
  documentRevisionNo    Int?
  supersededAt          DateTime?
  supersededByRevisionNo Int?
  voidedAt              DateTime?
  voidedById            String?
  voidReversalOf        String?
  createdById           String
  createdBy             User                   @relation(fields: [createdById], references: [id])
  createdAt             DateTime               @default(now())

  @@index([materialId])
  @@index([warehouseId])
  @@index([transferId])
  @@index([stocktakeId])
  @@index([documentId])
  @@index([documentLineId])
  @@index([createdById])
  @@index([createdAt])
}

model InventoryDocument {
  id              String                  @id @default(cuid())
  code            String                  @unique
  kind            InventoryDocumentKind
  status          InventoryDocumentStatus @default(DRAFT)
  documentDate    DateTime
  warehouseId     String?
  warehouse       Warehouse?              @relation("DocumentWarehouse", fields: [warehouseId], references: [id])
  fromWarehouseId String?
  fromWarehouse   Warehouse?              @relation("DocumentFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse?              @relation("DocumentToWarehouse", fields: [toWarehouseId], references: [id])
  supplierId      String?
  supplier        Supplier?               @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  reason          MovementReason?
  transferReason  String?
  note            String?
  revisionNo      Int                     @default(1)
  createdById     String
  createdBy       User                    @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?                   @relation("DocumentUpdatedBy", fields: [updatedById], references: [id])
  postedById      String?
  postedBy        User?                   @relation("DocumentPostedBy", fields: [postedById], references: [id])
  voidedById      String?
  voidedBy        User?                   @relation("DocumentVoidedBy", fields: [voidedById], references: [id])
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  postedAt        DateTime?
  voidedAt        DateTime?
  voidReason      String?
  lines           InventoryDocumentLine[]
  movements       StockMovement[]
  auditLogs       DocumentAuditLog[]

  @@index([kind, status])
  @@index([documentDate])
  @@index([warehouseId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([supplierId])
  @@index([createdById])
  @@index([updatedById])
  @@index([postedById])
  @@index([voidedById])
}

model InventoryDocumentLine {
  id         String            @id @default(cuid())
  documentId String
  document   InventoryDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lineNo     Int
  materialId String
  material   Material          @relation(fields: [materialId], references: [id])
  projectId  String?
  project    Project?          @relation(fields: [projectId], references: [id])
  workItemId String?
  workItem   ProjectWorkItem?  @relation(fields: [workItemId], references: [id])
  quantity   Float
  note       String?
  movements  StockMovement[]

  @@unique([documentId, lineNo])
  @@index([materialId])
  @@index([projectId])
  @@index([workItemId])
}

model Project {
  id          String                  @id @default(cuid())
  code        String                  @unique
  name        String
  status      ProjectStatus           @default(ACTIVE)
  warehouseId String?
  warehouse   Warehouse?              @relation(fields: [warehouseId], references: [id])
  note        String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  workItems   ProjectWorkItem[]
  norms       MaterialNorm[]
  funds       Fund[]
  documentLines InventoryDocumentLine[]

  @@index([warehouseId])
  @@index([status])
}

model ProjectWorkItem {
  id            String                  @id @default(cuid())
  projectId     String
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code          String?
  name          String
  isDefault     Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  norms         MaterialNorm[]
  documentLines InventoryDocumentLine[]

  @@unique([projectId, name])
  @@index([projectId])
}

model MaterialNorm {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workItemId  String
  workItem    ProjectWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material        @relation(fields: [materialId], references: [id])
  normQty     Float
  note        String?
  createdById String
  createdBy   User            @relation("MaterialNormCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?           @relation("MaterialNormUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([workItemId, materialId])
  @@index([projectId])
  @@index([materialId])
  @@index([createdById])
  @@index([updatedById])
}

model Fund {
  id        String         @id @default(cuid())
  code      String         @unique
  name      String
  projectId String?
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  note      String?
  createdAt DateTime       @default(now())
  documents FundDocument[]

  @@unique([projectId])
}

model FundDocument {
  id           String               @id @default(cuid())
  code         String               @unique
  fundId       String
  fund         Fund                 @relation(fields: [fundId], references: [id], onDelete: Cascade)
  kind         FundDocumentKind
  status       FundDocumentStatus   @default(DRAFT)
  documentDate DateTime
  note         String?
  revisionNo   Int                  @default(1)
  createdById  String
  createdBy    User                 @relation("FundDocumentCreatedBy", fields: [createdById], references: [id])
  postedById   String?
  postedBy     User?                @relation("FundDocumentPostedBy", fields: [postedById], references: [id])
  voidedById   String?
  voidedBy     User?                @relation("FundDocumentVoidedBy", fields: [voidedById], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  postedAt     DateTime?
  voidedAt     DateTime?
  voidReason   String?
  lines        FundDocumentLine[]
  auditLogs    FundDocumentAuditLog[]

  @@index([fundId, documentDate])
  @@index([kind, status])
  @@index([createdById])
  @@index([postedById])
  @@index([voidedById])
}

model FundDocumentLine {
  id          String       @id @default(cuid())
  documentId  String
  document    FundDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lineNo      Int
  amount      Float
  category    String
  description String
  note        String?

  @@unique([documentId, lineNo])
  @@index([category])
}

model FundDocumentAuditLog {
  id             String              @id @default(cuid())
  documentId     String
  document       FundDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  action         DocumentAuditAction
  fromRevisionNo Int?
  toRevisionNo   Int?
  reason         String?
  snapshotBefore Json?
  snapshotAfter  Json?
  changedById    String
  changedBy      User                @relation(fields: [changedById], references: [id])
  changedAt      DateTime            @default(now())

  @@index([documentId])
  @@index([changedById])
  @@index([changedAt])
}

model AccountingPeriodLock {
  id          String          @id @default(cuid())
  scope       PeriodLockScope
  fromDate    DateTime
  toDate      DateTime
  reason      String?
  createdById String
  createdBy   User            @relation("PeriodLockCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([scope, fromDate, toDate])
  @@index([createdById])
  @@index([createdAt])
}

model DocumentAuditLog {
  id             String            @id @default(cuid())
  documentId     String
  document       InventoryDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  action         DocumentAuditAction
  fromRevisionNo Int?
  toRevisionNo   Int?
  reason         String?
  snapshotBefore Json?
  snapshotAfter  Json?
  changedById    String
  changedBy      User              @relation(fields: [changedById], references: [id])
  changedAt      DateTime          @default(now())

  @@index([documentId])
  @@index([changedById])
  @@index([changedAt])
}

model Stocktake {
  id           String          @id @default(cuid())
  code         String          @unique
  status       StocktakeStatus @default(DRAFT)
  warehouseId  String
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  createdById  String
  createdBy    User            @relation("created", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?           @relation("approved", fields: [approvedById], references: [id])
  createdAt    DateTime        @default(now())
  approvedAt   DateTime?
  items        StocktakeItem[]
  adjustments  StockMovement[] @relation("stocktakeAdjustments")

  @@index([warehouseId])
  @@index([createdById])
  @@index([approvedById])
}

model StocktakeItem {
  id          String    @id @default(cuid())
  stocktakeId String
  stocktake   Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id])
  countedQty  Float
  systemQty   Float
  diff        Float

  @@index([stocktakeId])
  @@index([materialId])
}
