generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime serverless dùng pooled URL (Supabase pgbouncer, port 6543).
  url       = env("DATABASE_URL")
  // migrate deploy cần kết nối direct (port 5432) — pgbouncer transaction-mode không chạy migration được.
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  STAFF
}

enum MovementType {
  IN
  OUT
}

enum MovementReason {
  PURCHASE
  PROJECT
  DAMAGED
  EXPIRED
  NATURAL_LOSS
  STOCKTAKE_ADJUST
  TRANSFER_OUT
  TRANSFER_IN
  VOID
}

enum StocktakeStatus {
  DRAFT
  APPROVED
  VOIDED
}

enum DocType {
  IN
  OUT
  TRANSFER
  STOCKTAKE
}

enum DocStatus {
  DRAFT
  PENDING
  POSTED
  VOIDED
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  passwordHash       String
  name               String
  role               Role            @default(STAFF)
  createdAt          DateTime        @default(now())
  movements          StockMovement[]
  stocktakesCreated  Stocktake[]     @relation("created")
  stocktakesApproved Stocktake[]     @relation("approved")
  docsCreated        Document[]      @relation("docCreated")
  docsApproved       Document[]      @relation("docApproved")
  docsVoided         Document[]      @relation("docVoided")
  equipmentLogs      EquipmentLog[]
}

model Material {
  id             String          @id @default(cuid())
  name           String
  code           String          @unique
  unit           String
  minStock       Float           @default(0)
  createdAt      DateTime        @default(now())
  movements      StockMovement[]
  stocktakeItems StocktakeItem[]
  documentLines  DocumentLine[]
}

model Warehouse {
  id         String          @id @default(cuid())
  name       String
  code       String          @unique
  isDefault  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  movements  StockMovement[]
  stocktakes Stocktake[]
  docsWhse   Document[]      @relation("docWarehouse")
  docsFrom   Document[]      @relation("docFromWarehouse")
  docsTo     Document[]      @relation("docToWarehouse")
}

model StockMovement {
  id             String         @id @default(cuid())
  materialId     String
  material       Material       @relation(fields: [materialId], references: [id])
  warehouseId    String
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])
  type           MovementType
  quantity       Float
  reason         MovementReason
  note           String?
  transferId     String?
  stocktakeId    String?
  stocktake      Stocktake?     @relation("stocktakeAdjustments", fields: [stocktakeId], references: [id])
  documentId     String?
  document       Document?      @relation(fields: [documentId], references: [id])
  voidedAt       DateTime?
  voidedById     String?
  voidReversalOf String?
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())

  @@index([materialId])
  @@index([warehouseId])
  @@index([transferId])
  @@index([stocktakeId])
  @@index([documentId])
  @@index([createdAt])
}

model Stocktake {
  id           String          @id @default(cuid())
  code         String          @unique
  status       StocktakeStatus @default(DRAFT)
  warehouseId  String
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  createdById  String
  createdBy    User            @relation("created", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?           @relation("approved", fields: [approvedById], references: [id])
  createdAt    DateTime        @default(now())
  approvedAt   DateTime?
  items        StocktakeItem[]
  adjustments  StockMovement[] @relation("stocktakeAdjustments")
}

model StocktakeItem {
  id          String    @id @default(cuid())
  stocktakeId String
  stocktake   Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id])
  countedQty  Float
  systemQty   Float
  diff        Float
}

model Document {
  id              String          @id @default(cuid())
  code            String          @unique
  type            DocType
  status          DocStatus       @default(DRAFT)
  docDate         DateTime        @default(now())
  reason          String?
  warehouseId     String?
  warehouse       Warehouse?      @relation("docWarehouse", fields: [warehouseId], references: [id])
  fromWarehouseId String?
  fromWarehouse   Warehouse?      @relation("docFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse?      @relation("docToWarehouse", fields: [toWarehouseId], references: [id])
  supplierId      String?
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  note            String?
  createdById     String
  createdBy       User            @relation("docCreated", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?           @relation("docApproved", fields: [approvedById], references: [id])
  createdAt       DateTime        @default(now())
  postedAt        DateTime?
  voidedAt        DateTime?
  voidedById      String?
  voidedBy        User?           @relation("docVoided", fields: [voidedById], references: [id])
  transferId      String?
  lines           DocumentLine[]
  movements       StockMovement[]

  @@index([createdAt])
  @@index([type, status, docDate])
}

model DocumentLine {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Float
  note       String?

  @@index([documentId])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String
  contact   String?
  note      String?
  createdAt DateTime   @default(now())
  documents Document[]
}

model Equipment {
  id        String         @id @default(cuid())
  name      String
  type      String?
  plateNo   String?
  note      String?
  createdAt DateTime       @default(now())
  logs      EquipmentLog[]
}

model EquipmentLog {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  logDate     DateTime
  hours       Float
  note        String?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([equipmentId])
  @@index([logDate])
}
